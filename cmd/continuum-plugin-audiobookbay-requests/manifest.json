{
  "plugin_id": "continuum.audiobookbay-requests",
  "version": "1.0.0",
  "checksum": "1250f06209dc3fbfffe6bf2b475003cc8f49f8e64f1b75faeb2e1e22c93ed38e",
  "continuum_api_version": "v1",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "http_routes.v1",
      "id": "backend",
      "display_name": "AudiobookBay Requests API",
      "description": "Request-provider API for scored AudiobookBay search, magnet resolution, diagnostics, and optional qBittorrent enqueueing."
    },
    {
      "type": "event_consumer.v1",
      "id": "request_handler",
      "display_name": "Audiobook request handler",
      "description": "Forwards audiobook request_submitted events to AudiobookBay search and the configured download mode.",
      "subscriptions": [
        "plugin.continuum.audiobooks.request_submitted"
      ]
    },
    {
      "type": "audiobook_backend.v1",
      "id": "default",
      "display_name": "AudiobookBay Requests",
      "description": "Scraper-based audiobook request provider backed by AudiobookBay with optional qBittorrent enqueueing; not a presentation library source.",
      "metadata": {
        "audiobook_roles": [
          "request_provider"
        ],
        "supports_catalog": false,
        "supports_requests": true,
        "supports_auto_monitoring": false
      }
    },
    {
      "type": "scheduled_task.v1",
      "id": "reconciler",
      "display_name": "Reconcile AudiobookBay request status",
      "description": "Polls embedded/qBittorrent download status for non-terminal audiobook requests.",
      "cron": "*/1 * * * *"
    }
  ],
  "http_routes": [
    {
      "id": "api",
      "method": "*",
      "path": "/api/v1/*",
      "access": "authenticated"
    },
    {
      "id": "admin",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "AudiobookBay Requests",
      "navigation_kind": "admin"
    },
    {
      "id": "admin_sub",
      "method": "GET",
      "path": "/admin/*",
      "access": "admin"
    }
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Postgres connection string",
      "description": "DSN for the dedicated AudiobookBay requests schema.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Connection URL",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    },
    {
      "key": "base_url",
      "title": "AudiobookBay base URL",
      "description": "AudiobookBay base URL, e.g. https://audiobookbay.lu (no trailing slash).",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "URL",
            "control": "ADMIN_FORM_CONTROL_TEXT",
            "required": true
          }
        ]
      }
    },
    {
      "key": "download_mode",
      "title": "Download mode",
      "description": "One of scrape_only, qbittorrent, or embedded. Defaults to qbittorrent when qBittorrent URL is set, otherwise scrape_only.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\",\"enum\":[\"scrape_only\",\"qbittorrent\",\"embedded\"]}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Mode",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "qbittorrent_url",
      "title": "qBittorrent Web UI URL",
      "description": "Optional base URL for qBittorrent Web API, e.g. http://qbittorrent:8080. Leave blank for scrape-only magnet resolution.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "URL",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "qbittorrent_username",
      "title": "qBittorrent username",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Username",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "qbittorrent_password",
      "title": "qBittorrent password",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Password",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "secret": true
          }
        ]
      }
    },
    {
      "key": "qbittorrent_category",
      "title": "qBittorrent category",
      "description": "Optional category assigned to enqueued audiobook torrents.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Category",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "qbittorrent_save_path",
      "title": "qBittorrent save path",
      "description": "Optional save path sent to qBittorrent for new audiobook requests.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Save path",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "embedded_download_dir",
      "title": "Embedded download directory",
      "description": "Required when download_mode is embedded. Completed torrent files are written here.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Download directory",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "embedded_listen_port",
      "title": "Embedded torrent listen port",
      "description": "Optional BitTorrent listen port for embedded mode. Leave blank/0 for a random port.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"number\",\"minimum\":0,\"maximum\":65535}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Listen port",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          }
        ]
      }
    },
    {
      "key": "trackers",
      "title": "Fallback trackers",
      "description": "JSON array of trackers used when AudiobookBay exposes an info hash without a full magnet URI.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Trackers (JSON array)",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "search_limit",
      "title": "Search result limit",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"number\",\"minimum\":1,\"maximum\":50}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Limit",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          }
        ]
      }
    }
  ]
}
